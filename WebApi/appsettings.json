{
  "ConnectionStrings": {
    "UniversityDb": "Data Source=university.db"
  },
  "Jwt": {
    "Issuer": "UniversityApiApp",
    "Audience": "AppClient",
    "SecretKey": "YOUR_SECRET_KEY_HERE_MIN_32_CHARS",
    "ExpiryInMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
